<div class="modal-body">
  <div class="nextcloud-file-name-modal">
    <h3>Create {{model.fileTypeLabel}}</h3>
    
    <div class="control-group">
      <label class="control-label">File Name</label>
      <div class="controls">
        <input 
          type="text" 
          class="input-large" 
          value={{fileName}} 
          {{on "input" (action "updateFileName")}}
          {{on "keydown" (action "handleKeyDown")}}
          placeholder="Enter file name..."
          autofocus
        />
        <div class="control-instructions">
          The file extension will be added automatically.
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal-footer">
  <button 
    class="btn btn-primary" 
    {{action "confirm"}}
    disabled={{isLoading}}
  >
    {{#if isLoading}}
      Creating...
    {{else}}
      Create File
    {{/if}}
  </button>
  
  <button 
    class="btn" 
    {{action "cancel"}}
    disabled={{isLoading}}
  >
    Cancel
  </button>
</div>
